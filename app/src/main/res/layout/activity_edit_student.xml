<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_login"> <View
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CẬP NHẬT"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#8B5E3C"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SỬA THÔNG TIN SINH VIÊN"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp"
                    android:gravity="center"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="110dp"
                android:layout_height="110dp"
                app:cardCornerRadius="55dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_login_card"
                android:padding="24dp">

                <EditText
                    android:id="@+id/edtName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Họ và tên"
                    android:inputType="textPersonName"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="#333333"
                    android:textColorHint="#A0A0A0"
                    android:background="@drawable/bg_menu_item"
                    android:layout_marginBottom="16dp"
                    android:nextFocusDown="@id/edtCode"
                    android:imeOptions="actionNext"/>

                <EditText
                    android:id="@+id/edtCode"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Mã số sinh viên (MSSV)"
                    android:inputType="text"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="#333333"
                    android:textColorHint="#A0A0A0"
                    android:background="@drawable/bg_menu_item"
                    android:layout_marginBottom="16dp"
                    android:nextFocusDown="@id/edtPhone"
                    android:imeOptions="actionNext"/>

                <EditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Số điện thoại"
                    android:inputType="phone"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="#333333"
                    android:textColorHint="#A0A0A0"
                    android:background="@drawable/bg_menu_item"
                    android:layout_marginBottom="16dp"
                    android:nextFocusDown="@id/edtEmail"
                    android:imeOptions="actionNext"/>

                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Địa chỉ Email"
                    android:inputType="textEmailAddress"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="#333333"
                    android:textColorHint="#A0A0A0"
                    android:background="@drawable/bg_menu_item"
                    android:imeOptions="actionDone"/>

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:text="Lưu thay đổi"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_login" /> </LinearLayout>
    </ScrollView>
</RelativeLayout>